{
    "name": "Imgur Unblocker (Imgup)",
    "version": "2.0.3",
    "description": "Replaces all imgur image links with the imgup proxy. \nModified by who_else123 to change the proxy from DuckDuckGo to Imgup due to new restrictions imposed by Imgur. \nCredit to HexedHero for developing the original extension!",
    "manifest_version": 3,
    "permissions": [
        "declarativeNetRequest",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}
